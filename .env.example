# FieldRoutes API Credentials
# ─────────────────────────────────────────────────────────────
# INSTRUCTIONS FOR CONTRACTOR:
#   1. Copy this file and rename it to: .env
#   2. Fill in your actual values below
#   3. NEVER commit the .env file to GitHub — it contains secrets
#   4. NEVER share .env via email or Slack
# ─────────────────────────────────────────────────────────────

# Your FieldRoutes API key
# Where to find it: FieldRoutes Admin → Settings → API → Generate Key
FR_API_KEY=your_api_key_here

# Your FieldRoutes Office ID
# Where to find it: FieldRoutes Admin → Settings → Office Info
# It is usually a 4–6 digit number
FR_OFFICE_ID=your_office_id_here

# FieldRoutes API base URL — do not change unless instructed
FR_BASE_URL=https://api.fieldroutes.com

# How many days back to pull data
# Use 30 on your FIRST run to get historical data
# Use 1 for all daily runs after that
LOOKBACK_DAYS=1
